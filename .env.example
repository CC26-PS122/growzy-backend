# ========================================
# GROWZY BACKEND - Environment Variables
# ========================================
# Copy file ini ke .env dan isi dengan nilai Anda
# DO NOT COMMIT .env FILE!

# ========================================
# SUPABASE CONFIGURATION
# ========================================
# Dapatkan nilai dari Supabase Dashboard → Project Settings → API

# URL project Supabase
# Format: https://your-project.supabase.co
SUPABASE_URL=https://your-project-id.supabase.co

# Public Anonymous Key dari Supabase
# Format: eyJhbGc... (panjang JWT key)
SUPABASE_ANON_KEY=your-anon-key-here

# ========================================
# SERVER CONFIGURATION
# ========================================

# Port lokal untuk menjalankan server
# Default: 4000
PORT=4000

# Environment mode ('development' atau 'production')
# Default: development
NODE_ENV=development
